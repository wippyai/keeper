<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HIL Approval</title>
    <base href="{{ env.hostname }}">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@2.37.0/tabler-icons.min.css">
    {{ if isset(resources.style) }}
    {{ range resources.style }}
    {{ if isset(.url) }}
    <link rel="stylesheet" href="{{ .url }}"{{ if isset(.crossorigin) }} crossorigin="{{ .crossorigin }}"{{ end }}>
    {{ end }}
    {{ if isset(.inline) }}
    <style>{{ .inline }}</style>
    {{ end }}
    {{ end }}
    {{ end }}
    {{ if isset(resources.script) }}
    {{ range resources.script }}
    {{ if isset(.url) }}
    <script src="{{ .url }}"{{ if isset(.defer) }} defer{{ end }}{{ if isset(.async) }} async{{ end }}></script>
    {{ end }}
    {{ end }}
    {{ end }}
</head>
<body class="bg-surface-50 dark:bg-surface-900">
<div class="py-3 max-w-8xl mx-auto">
    <div id="statusBanner" class="hidden p-3 mx-1 rounded-md text-sm text-center mb-3">
        <span id="statusMessage"></span>
    </div>

    <div class="flex items-center justify-between p-2 mx-3 bg-surface-100 dark:bg-surface-800 rounded-md mb-3 text-xs">
        <div class="flex items-center gap-3">
            <div class="flex items-center gap-1 text-surface-600 dark:text-surface-400">
                <i class="ti ti-file-diff"></i>
                <span class="font-semibold text-surface-900 dark:text-surface-100">{{ isset(data.changeset_count) ? data.changeset_count : 0 }}</span>
                <span>changes</span>
            </div>
            <div class="flex items-center gap-1 text-surface-600 dark:text-surface-400">
                <i class="ti ti-clock"></i>
                <span id="currentTime">now</span>
            </div>
            {{ if isset(data.options.message) }}
            <div class="flex items-center gap-1 text-surface-600 dark:text-surface-400 cursor-pointer flex-1 min-w-0" onclick="toggleMessage()">
                <i class="ti ti-message-circle flex-shrink-0"></i>
                <span id="messagePreview" class="truncate" style="max-width: 300px;">{{ data.options.message }}</span>
                <i class="ti ti-chevron-down flex-shrink-0" id="messageChevron"></i>
            </div>
            {{ end }}
        </div>
        <div class="font-mono text-primary-600 dark:text-primary-400 cursor-pointer px-2 py-1 rounded hover:bg-surface-200 dark:hover:bg-surface-700 transition-colors text-xs" onclick="navigateToWorkspace()" title="{{ isset(data.options.workspace_id) ? data.options.workspace_id : "unknown" }}">
        {{ isset(data.options.workspace_id) ? (len(data.options.workspace_id) > 8 ? data.options.workspace_id[:8] + "…" : data.options.workspace_id) : "unknown" }}
    </div>
</div>

{{ if isset(data.options.message) }}
<div id="fullMessage" class="hidden p-3 mx-3 bg-surface-100 dark:bg-surface-800 rounded-md mb-3 text-sm text-surface-700 dark:text-surface-300 border-l-4 border-primary-500" style="white-space: pre-wrap;">{{ data.options.message }}</div>
{{ end }}

<div class="mb-3 mx-3">
    <div class="bg-surface-100 dark:bg-surface-800 rounded-md p-1 max-h-60 overflow-y-auto">
        {{ if isset(data.changeset) }}
        {{ range data.changeset }}
        {{ try }}
        <div class="flex items-center gap-2 px-2 py-1 text-xs hover:bg-surface-200 dark:hover:bg-surface-700 rounded transition-colors">
            {{ changeKind := isset(.kind) ? .kind : "unknown" }}
            <div class="w-4 h-4 flex items-center justify-center flex-shrink-0 {{ changeKind == "entry.create" ? "text-green-500" : (changeKind == "entry.delete" ? "text-red-500" : "text-blue-500") }}">
            {{ if (changeKind == "entry.create") }}
            <i class="ti ti-plus"></i>
            {{ else if (changeKind == "entry.delete") }}
            <i class="ti ti-trash"></i>
            {{ else }}
            <i class="ti ti-pencil"></i>
            {{ end }}
        </div>
        <div class="flex items-center gap-2 flex-1 min-w-0">
            {{ if isset(.entry) }}
            <div class="font-mono text-xs font-medium text-primary-700 dark:text-primary-300">{{ isset(.entry.id) ? .entry.id : "unknown" }}</div>
            {{ if (changeKind != "entry.delete") }}
            {{ entryKind := isset(.entry.kind) ? .entry.kind : changeKind }}
            {{ metaType := isset(.entry.meta) && isset(.entry.meta.type) ? .entry.meta.type : "" }}
            <div class="text-xs text-surface-500 dark:text-surface-400">
                {{ entryKind }}{{ metaType != "" ? " [" + metaType + "]" : "" }}
            </div>
            {{ end }}
            {{ else }}
            {{ if (changeKind == "entry.delete") }}
            <div class="font-mono text-xs font-medium text-red-600 dark:text-red-400">deleted entry</div>
            {{ else }}
            <div class="font-mono text-xs font-medium text-red-600 dark:text-red-400">corrupted entry</div>
            <div class="text-xs text-surface-500 dark:text-surface-400">{{ changeKind }}</div>
            {{ end }}
            {{ end }}
        </div>
    </div>
    {{ catch err }}
    <div class="flex items-center gap-2 px-2 py-1 text-xs bg-red-50 dark:bg-red-900 rounded transition-colors">
        <div class="w-4 h-4 flex items-center justify-center flex-shrink-0 text-red-500">
            <i class="ti ti-alert-triangle"></i>
        </div>
        <div class="flex items-center gap-2 flex-1 min-w-0">
            <div class="font-mono text-xs font-medium text-red-600 dark:text-red-400">corrupted changeset entry</div>
            <div class="text-xs text-red-500 dark:text-red-400">error: {{ err }}</div>
        </div>
    </div>
    {{ end }}
    {{ end }}
    {{ else }}
    <div class="flex items-center justify-center p-4 text-surface-500 dark:text-surface-400 text-sm">
        <i class="ti ti-info-circle mr-2"></i>
        No changeset data available
    </div>
    {{ end }}
</div>
</div>

<div id="actionsRow" class="flex gap-2 items-center mx-3">
    <input type="text" id="reasonInput" class="flex-1 p-2 border border-surface-300 dark:border-surface-600 rounded-md text-sm bg-surface-50 dark:bg-surface-800 text-surface-900 dark:text-surface-100 placeholder-surface-500 dark:placeholder-surface-400 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent" placeholder="Optional reason...">
    <button onclick="approve()" id="approveBtn" class="px-3 py-2 border-0 rounded-md text-sm font-medium cursor-pointer flex items-center gap-1 transition-all min-w-20 justify-center bg-emerald-600 hover:bg-emerald-700 text-white disabled:opacity-50 disabled:cursor-not-allowed">
                <span id="approveText">
                    <i class="ti ti-check"></i>
                    Approve
                </span>
    </button>
    <button onclick="reject()" id="rejectBtn" class="px-3 py-2 border-0 rounded-md text-sm font-medium cursor-pointer flex items-center gap-1 transition-all min-w-20 justify-center bg-rose-600 hover:bg-rose-700 text-white disabled:opacity-50 disabled:cursor-not-allowed">
                <span id="rejectText">
                    <i class="ti ti-x"></i>
                    Reject
                </span>
    </button>
</div>
</div>

<script>
    let wippyApi = null;
    let isProcessing = false;
    let messageExpanded = false;

    function updateTime() {
        document.getElementById('currentTime').textContent = new Date().toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});
    }
    updateTime();

    function toggleMessage() {
        const fullMessage = document.getElementById('fullMessage');
        const chevron = document.getElementById('messageChevron');

        messageExpanded = !messageExpanded;

        if (messageExpanded) {
            fullMessage.classList.remove('hidden');
            chevron.className = 'ti ti-chevron-up';
        } else {
            fullMessage.classList.add('hidden');
            chevron.className = 'ti ti-chevron-down';
        }
    }

    async function init() {
        try {
            wippyApi = await window.initWippyApi();
            console.log('HIL approval initialized');
        } catch (error) {
            console.error('Failed to initialize HIL:', error);
            showStatus('Failed to initialize approval interface', 'error');
        }
    }

    function navigateToWorkspace() {
        if (wippyApi && wippyApi.iframe) {
            {{ workspaceId := isset(data.options.workspace_id) ? data.options.workspace_id : "unknown" }}
            wippyApi.iframe.navigate('/c/keeper.views.overlay:view/{{ workspaceId }}');
        }
    }

    async function approve() {
        await sendDecision(true);
    }

    async function reject() {
        await sendDecision(false);
    }

    async function sendDecision(approved) {
        if (isProcessing) return;
        isProcessing = true;

        const approveBtn = document.getElementById('approveBtn');
        const rejectBtn = document.getElementById('rejectBtn');
        const reasonInput = document.getElementById('reasonInput');

        approveBtn.disabled = true;
        rejectBtn.disabled = true;

        const loadingHtml = '<div class="w-3 h-3 border-2 border-transparent border-t-current rounded-full animate-spin"></div>Processing...';
        if (approved) {
            document.getElementById('approveText').innerHTML = loadingHtml;
        } else {
            document.getElementById('rejectText').innerHTML = loadingHtml;
        }

        try {
            const endpoint = approved ? 'approve' : 'reject';
            {{ requestId := isset(data.request_id) ? data.request_id : "unknown" }}
            const apiUrl = `/api/v1/hil/{{ requestId }}/${endpoint}`;

            const requestBody = {};
            if (reasonInput.value && reasonInput.value.trim()) {
                requestBody.reason = reasonInput.value.trim();
            }

            const response = await wippyApi.api.post(apiUrl, requestBody);

            if (!response.data || !response.data.success) {
                throw new Error(response.data?.error || `Failed to ${endpoint} request`);
            }

            showStatus(
                approved ? 'Changes approved successfully!' : 'Changes rejected successfully!',
                'success'
            );

        } catch (error) {
            console.error('Error sending decision:', error);
            showStatus(`Failed to send decision: ${error.message}`, 'error');

            document.getElementById('approveText').innerHTML = '<i class="ti ti-check"></i>Approve';
            document.getElementById('rejectText').innerHTML = '<i class="ti ti-x"></i>Reject';
            approveBtn.disabled = false;
            rejectBtn.disabled = false;
        } finally {
            isProcessing = false;
        }
    }

    function showStatus(message, type) {
        const banner = document.getElementById('statusBanner');
        const messageEl = document.getElementById('statusMessage');
        const actionsRow = document.getElementById('actionsRow');

        messageEl.textContent = message;

        if (type === 'success') {
            banner.className = 'p-3 mx-3 rounded-md text-sm text-center mb-3 bg-green-100 dark:bg-green-900 text-green-800 dark:text-green-200 border border-green-200 dark:border-green-700';
        } else {
            banner.className = 'p-3 mx-3 rounded-md text-sm text-center mb-3 bg-red-100 dark:bg-red-900 text-red-800 dark:text-red-200 border border-red-200 dark:border-red-700';
        }

        banner.classList.remove('hidden');
        actionsRow.style.display = 'none';
    }

    init();
</script>
</body>
</html>