                        life: 3000
                    });
                } catch (err) {
                    console.error('Error deleting entry:', err);
                    this.wippyApi.iframe.toast({
                        severity: 'error',
                        summary: 'Delete Failed',
                        detail: err.message,
                        life: 5000
                    });
                }
            },

            closeEntryEditor() {
                this.showEntryEditor = false;
                this.editingEntryId = null;
                this.entryEditorContent = '';
                this.entryEditorPreview = null;
            },

            refreshWorkspace() {
                this.loadWorkspace();
            },

            goBackToList() {
                if (this.wippyApi?.iframe?.navigate) {
                    this.wippyApi.iframe.navigate('/c/keeper.views.overlay:list');
                } else {
                    window.location.href = '/workspaces';
                }
            },

            // Enhanced functionality methods
            async waitForDependencies() {
                // Wait for Prism.js
                let attempts = 0;
                while (!window.prismReady && attempts < 50) {
                    await new Promise(resolve => setTimeout(resolve, 100));
                    attempts++;
                }

                if (!window.prismReady) {
                    console.error('Prism.js failed to initialize within timeout');
                    return;
                }

                this.prismReady = true;
                console.log('All dependencies ready');
            },

            initializeSyntaxHighlighting() {
                // Configure Prism for better performance
                if (typeof Prism !== 'undefined') {
                    Prism.manual = true;
                    Prism.plugins.autoloader.languages_path =
                        'https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/';

                    // Define custom Wippy-specific language mappings
                    if (Prism.languages) {
                        // Ensure base language exists before extending
                        if (!Prism.languages.lua) {
                            Prism.languages.lua = {};
                        }

                        Prism.languages.wippy = Prism.languages.extend('lua', {
                            'registry-key': {
                                pattern: /[a-zA-Z_][a-zA-Z0-9_]*:[a-zA-Z_][a-zA-Z0-9_]*/,
                                alias: 'namespace'
                            },
                            'entry-kind': {
                                pattern: /\b(function\.lua|library\.lua|registry\.entry|contract\.(definition|binding))\b/,
                                alias: 'builtin'
                            }
                        });
                    }

                    console.log('Syntax highlighting initialized');
                }
            },

            setupThemeManagement() {
                // Initialize theme state
                this.updatePrismTheme();

                // Watch for theme changes
                this.$watch('isDarkMode', (isDark) => {
                    this.updatePrismTheme(isDark);
                });

                // Listen for system theme changes
                const mediaQuery = window.matchMedia('(prefers-color-scheme: dark)');
                mediaQuery.addListener(() => {
                    if (!this.hasExplicitTheme) {
                        this.updatePrismTheme();
                    }
                });
            },

            updatePrismTheme(isDark = null) {
                if (isDark === null) {
                    isDark = document.documentElement.classList.contains('dark');
                }

                const lightTheme = document.getElementById('prism-light');
                const darkTheme = document.getElementById('prism-dark');

                if (lightTheme && darkTheme) {
                    lightTheme.disabled = isDark;
                    darkTheme.disabled = !isDark;

                    // Re-highlight visible content with new theme
                    setTimeout(() => {
                        this.highlightVisibleContent(true);
                    }, 100);
                }
            },

            setupContentObservers() {
                // Use Intersection Observer for visibility
                const observer = new IntersectionObserver((entries) => {
                    entries.forEach(entry => {
                        if (entry.isIntersecting && !entry.target.dataset.highlighted) {
                            this.scheduleHighlighting(entry.target);
                        }
                    });
                }, { threshold: 0.1 });

                // Observe code elements
                const codeElements = document.querySelectorAll('pre code');
                codeElements.forEach(el => observer.observe(el));

                // Mutation observer for dynamic content
                const mutationObserver = new MutationObserver((mutations) => {
                    mutations.forEach(mutation => {
                        if (mutation.type === 'childList') {
                            const newCodeElements = mutation.target.querySelectorAll('pre code:not([data-observed])');
                            newCodeElements.forEach(el => {
                                el.dataset.observed = 'true';
                                observer.observe(el);
                            });
                        }
                    });
                });

                mutationObserver.observe(document.body, {
                    childList: true,
                    subtree: true
                });
            },

            scheduleHighlighting(element, language = null, context = '') {
                // Debounced highlighting
                clearTimeout(element.highlightTimeout);
                element.highlightTimeout = setTimeout(() => {
                    this.highlightElement(element, language);
                }, 150);
            },

            async highlightElement(element, language = null, forceRefresh = false) {
                if (!this.prismReady || !element) return;

                // Prevent duplicate highlighting
                const elementId = element.dataset.highlightId || this.generateElementId();
                element.dataset.highlightId = elementId;

                if (this.highlightingQueue.has(elementId) && !forceRefresh) {
                    return;
                }

                this.highlightingQueue.add(elementId);

                try {
                    // Wait for content to be stable
                    await this.$nextTick();
                    await new Promise(resolve => setTimeout(resolve, 50));

                    // Detect language if not provided
                    const detectedLanguage = language || this.detectLanguage({ source: element.textContent });

                    // Clean previous highlighting
                    this.cleanHighlighting(element);

                    // Apply new highlighting
                    element.className = `language-${detectedLanguage}`;

                    // Use Prism with error handling
                    if (typeof Prism !== 'undefined' && Prism.highlightElement) {
                        Prism.highlightElement(element);
                    }

                    // Mark as highlighted
                    element.dataset.highlighted = 'true';
                    element.dataset.highlightLanguage = detectedLanguage;

                } catch (error) {
                    console.warn('Syntax highlighting failed for element:', error);
                    this.handleHighlightingError(element, error);
                } finally {
                    this.highlightingQueue.delete(elementId);
                }
            },

            cleanHighlighting(element) {
                // Remove Prism-generated content
                const tokens = element.querySelectorAll('.token');
                tokens.forEach(token => {
                    token.replaceWith(document.createTextNode(token.textContent));
                });

                // Reset classes
                element.className = element.className.replace(/language-\w+/g, '');
                delete element.dataset.highlighted;
                delete element.dataset.highlightLanguage;
            },

            async highlightVisibleContent(force = false) {
                if (this.highlightingInProgress && !force) return;

                this.highlightingInProgress = true;

                try {
                    const codeElements = document.querySelectorAll('pre code');
                    const visibleElements = Array.from(codeElements).filter(el =>
                        this.isElementVisible(el) && (!el.dataset.highlighted || force)
                    );

                    // Process in batches to avoid blocking UI
                    const batchSize = 5;
                    for (let i = 0; i < visibleElements.length; i += batchSize) {
                        const batch = visibleElements.slice(i, i + batchSize);

                        await Promise.all(batch.map(element =>
                            this.highlightElement(element)
                        ));

                        // Allow UI breathing room
                        await new Promise(resolve => setTimeout(resolve, 10));
                    }

                } finally {
                    this.highlightingInProgress = false;
                }
            },

            generateElementId() {
                return 'highlight_' + Math.random().toString(36).substr(2, 9);
            },

            handleHighlightingError(element, error) {
                console.warn('Highlighting failed:', error);

                // Apply basic syntax classes as fallback
                if (element.textContent.includes('function')) {
                    element.classList.add('language-lua', 'fallback-highlight');
                } else if (element.textContent.includes('{')) {
                    element.classList.add('language-json', 'fallback-highlight');
                }

                // Report error for debugging
                this.reportHighlightingError(error, element);
            },

            reportHighlightingError(error, element) {
                // Optional: Report to monitoring system
                console.debug('Highlighting error details:', {
                    error: error.message,
                    elementContent: element.textContent.substring(0, 100),
                    elementClasses: element.className
                });
            },

            // Enhanced metadata processing
            processEntryMetadata(views) {
                const processed = {
                    current: this.sortedMetadata(views.merged || views.workspace || {}),
                    original: views.original ? this.sortedMetadata(views.original) : null,
                    workspace: views.workspace ? this.sortedMetadata(views.workspace) : null
                };

                return processed;
            },

            sortedMetadata(metadata) {
                if (!metadata || typeof metadata !== 'object') return [];

                const systemKeys = ['name', 'kind', 'version', 'created_at', 'updated_at'];
                const entryKeys = ['source', 'method', 'modules', 'imports', 'pool', 'meta'];

                const result = {
                    system: { name: 'system', items: [] },
                    entry: { name: 'entry', items: [] },
                    custom: { name: 'custom', items: [] },
                    technical: { name: 'technical', items: [] }
                };

                Object.keys(metadata).forEach(key => {
                    const value = metadata[key];

                    // Skip problematic or internal keys
                    if (this.shouldSkipMetadataKey(key, value)) return;

                    if (systemKeys.includes(key)) {
                        result.system.items.push([key, value]);
                    } else if (entryKeys.includes(key)) {
                        result.entry.items.push([key, value]);
                    } else if (key.startsWith('_') || key.includes('internal') || key.includes('entry_meta')) {
                        result.technical.items.push([key, value]);
                    } else {
                        result.custom.items.push([key, value]);
                    }
                });

                // Sort each category
                result.system.items.sort(([a], [b]) => systemKeys.indexOf(a) - systemKeys.indexOf(b));
                result.entry.items.sort(([a], [b]) => entryKeys.indexOf(a) - entryKeys.indexOf(b));
                result.custom.items.sort(([a], [b]) => a.localeCompare(b));
                result.technical.items.sort(([a], [b]) => a.localeCompare(b));

                return Object.values(result).filter(category => category.items.length > 0);
            },

            shouldSkipMetadataKey(key, value) {
                // Skip null/undefined values
                if (value === null || value === undefined) return true;

                // Skip weird entry_meta keys mentioned in requirements
                if (key.includes('entry_meta') || key.startsWith('__weird')) return true;

                // Skip empty objects/arrays
                if (typeof value === 'object' && Object.keys(value).length === 0) return true;

                return false;
            },

            // Enhanced diff generation
            async generateEnhancedDiff(original, modified) {
                if (!original || !modified) return null;

                const originalText = this.extractTextForDiff(original);
                const modifiedText = this.extractTextForDiff(modified);

                if (originalText === modifiedText) return null;

                // Use diff library for unified diff
                if (typeof Diff !== 'undefined') {
                    const diffResult = Diff.createTwoFilesPatch(
                        'original', 'modified',
                        originalText, modifiedText,
                        '', '',
                        { context: 3 }
                    );

                    // Parse and enhance the diff
                    return this.parseDiffResult(diffResult);
                }

                return null;
            },

            extractTextForDiff(content) {
                if (content.source) return content.source;

                // For non-source content, create a readable representation
                const entries = [];
                Object.keys(content).sort().forEach(key => {
                    if (!this.shouldSkipMetadataKey(key, content[key])) {
                        entries.push(`${key}: ${JSON.stringify(content[key], null, 2)}`);
                    }
                });

                return entries.join('\n');
            },

            parseDiffResult(diffText) {
                const lines = diffText.split('\n');
                const chunks = [];
                let currentChunk = null;

                lines.forEach(line => {
                    if (line.startsWith('@@')) {
                        // New chunk header
                        if (currentChunk) chunks.push(currentChunk);
                        currentChunk = {
                            type: 'change',
                            header: line,
                            lines: [],
                            statistics: { added: 0, deleted: 0, modified: 0 }
                        };
                    } else if (currentChunk) {
                        const type = line.startsWith('+') ? 'added' :
                            line.startsWith('-') ? 'deleted' : 'context';

                        currentChunk.lines.push({
                            type,
                            content: line.substring(1), // Remove +/- prefix
                            marker: line.charAt(0)
                        });

                        if (type !== 'context') {
                            currentChunk.statistics[type]++;
                        }
                    }
                });

                if (currentChunk) chunks.push(currentChunk);

                return {
                    chunks,
                    totalChanges: chunks.reduce((sum, chunk) =>
                        sum + chunk.statistics.added + chunk.statistics.deleted, 0)
                };
            },

            // View mode management
            async setEntryViewMode(entryId, mode) {
                this.entryViewModes[entryId] = mode;
                this.entryViewModes = { ...this.entryViewModes };

                // Clear highlighting queue for this entry
                this.clearEntryHighlighting(entryId);

                // Wait for DOM updates
                await this.$nextTick();

                // Re-highlight new content
                setTimeout(() => {
                    this.highlightEntryContent(entryId);
                }, 100);
            },

            async highlightEntryContent(entryId) {
                const entryElements = document.querySelectorAll(
                    `[data-entry-id="${entryId}"] pre code`
                );

                for (const element of entryElements) {
                    await this.highlightElement(element);
                }
            },

            clearEntryHighlighting(entryId) {
                const entryElements = document.querySelectorAll(
                    `[data-entry-id="${entryId}"] pre code[data-highlighted]`
                );

                entryElements.forEach(element => {
                    this.cleanHighlighting(element);
                });
            },

            // Syntax highlighting utilities
            detectLanguage(content) {
                if (!content) return 'text';

                if (content.source) {
                    const source = content.source;

                    // Lua detection
                    if (source.includes('function') && source.includes('end')) return 'lua';
                    if (source.includes('local ') || source.includes('require(')) return 'lua';

                    // YAML detection
                    if (source.includes('version:') || source.includes('entries:')) return 'yaml';
                    if (source.match(/^[a-zA-Z_][a-zA-Z0-9_]*:\s/m)) return 'yaml';

                    // JSON detection
                    if (source.trim().startsWith('{') && source.trim().endsWith('}')) return 'json';

                    // Shell/Bash detection
                    if (source.includes('#!/bin/bash') || source.includes('#!/bin/sh')) return 'bash';
                }

                // Check for kind-based language mapping
                if (content.kind) {
                    if (content.kind.includes('lua')) return 'lua';
                    if (content.kind.includes('yaml')) return 'yaml';
                    if (content.kind.includes('json')) return 'json';
                }

                return 'text';
            },

            // Legacy method - redirects to enhanced version
            highlightCode(element, language = null) {
                return this.highlightElement(element, language);
            },

            // Legacy method - redirects to enhanced version
            highlightVisibleCode() {
                return this.highlightVisibleContent();
            },

            isElementVisible(element) {
                const rect = element.getBoundingClientRect();
                return rect.top < window.innerHeight && rect.bottom > 0;
            },

            getContentFromElement(element) {
                // Helper to extract content for language detection
                return { source: element.textContent };
            },

            // Enhanced utility methods
            formatMetadataValue(value, key) {
                if (value === null || value === undefined) return 'null';

                // Special formatting for specific keys
                if (key.includes('_at') && typeof value === 'string') {
                    return this.formatDate(value);
                }

                if (typeof value === 'object') {
                    if (Array.isArray(value)) {
                        return value.length === 0 ? '[]' :
                            value.length === 1 ? `[${JSON.stringify(value[0])}]` :
                                `[${value.length} items]`;
                    }
                    return JSON.stringify(value, null, 2);
                }

                if (typeof value === 'string' && value.length > 50) {
                    return value.substring(0, 50) + '...';
                }

                return String(value);
            },

            copyToClipboard(text) {
                navigator.clipboard.writeText(text).then(() => {
                    this.wippyApi.iframe.toast({
                        severity: 'success',
                        summary: 'Copied',
                        detail: 'Content copied to clipboard',
                        life: 2000
                    });
                }).catch(err => {
                    console.warn('Copy failed:', err);
                });
            },

            getCategoryIcon(categoryName) {
                switch(categoryName) {
                    case 'system': return 'tabler:info-circle';
                    case 'entry': return 'tabler:settings';
                    case 'custom': return 'tabler:tag';
                    case 'technical': return 'tabler:code';
                    default: return 'tabler:file';
                }
            },

            formatCategoryName(categoryName) {
                switch(categoryName) {
                    case 'system': return 'System Information';
                    case 'entry': return 'Entry Configuration';
                    case 'custom': return 'Custom Properties';
                    case 'technical': return 'Technical Details';
                    default: return categoryName;
                }
            },

            // Diff navigation
            navigateDiff(entryId, direction) {
                // Implementation for navigating between diff changes
                console.log(`Navigate diff for ${entryId} in direction ${direction}`);
            },

            canNavigateDiff(entryId, direction) {
                // Implementation to check if navigation is possible
                return false; // Placeholder
            },

            // Enhanced existing methods
            toggleEntryDetails(entryId) {
                this.expandedEntries[entryId] = !this.expandedEntries[entryId];
                this.expandedEntries = { ...this.expandedEntries };

                // Set default view mode for newly expanded entries
                if (this.expandedEntries[entryId] && !this.entryViewModes[entryId]) {
                    this.entryViewModes[entryId] = 'current';
                }

                // Trigger syntax highlighting after expansion
                this.$nextTick(() => {
                    this.highlightVisibleCode();
                });
            },

            // Helper methods
            getStatusBadgeClasses(status) {
                const baseClasses = 'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium';
                switch(status) {
                    case 'draft': return `${baseClasses} bg-gray-100 text-gray-800 dark:bg-gray-900 dark:text-gray-200`;
                    case 'active': return `${baseClasses} bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200`;
                    case 'reviewed': return `${baseClasses} bg-purple-100 text-purple-800 dark:bg-purple-900 dark:text-purple-200`;
                    case 'approved': return `${baseClasses} bg-teal-100 text-teal-800 dark:bg-teal-900 dark:text-teal-200`;
                    case 'committed': return `${baseClasses} bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200`;
                    case 'integrated': return `${baseClasses} bg-emerald-100 text-emerald-800 dark:bg-emerald-900 dark:text-emerald-200`;
                    case 'failed': return `${baseClasses} bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200`;
                    case 'archived': return `${baseClasses} bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200`;
                    default: return `${baseClasses} bg-purple-100 text-purple-800 dark:bg-purple-900 dark:text-purple-200`;
                }
            },

            getOperationBadgeClasses(operation) {
                const baseClasses = 'inline-flex items-center px-2 py-0.5 rounded text-xs font-medium';
                switch(operation) {
                    case 'create': return `${baseClasses} bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200`;
                    case 'update': return `${baseClasses} bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200`;
                    case 'delete': return `${baseClasses} bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200`;
                    default: return `${baseClasses} bg-gray-100 text-gray-800 dark:bg-gray-900 dark:text-gray-200`;
                }
            },

            getOperationIcon(operation) {
                switch(operation) {
                    case 'create': return 'tabler:plus';
                    case 'update': return 'tabler:edit';
                    case 'delete': return 'tabler:trash';
                    default: return 'tabler:question-mark';
                }
            },

            getHistoryIcon(operation) {
                switch(operation) {
                    case 'CREATE_WORKSPACE': return 'tabler:plus';
                    case 'UPDATE_WORKSPACE': return 'tabler:edit';
                    case 'DELETE_WORKSPACE': return 'tabler:trash';
                    case 'CREATE_WORKSPACE_ENTRY': return 'tabler:file-plus';
                    case 'UPDATE_WORKSPACE_ENTRY': return 'tabler:file-edit';
                    case 'DELETE_WORKSPACE_ENTRY': return 'tabler:file-minus';
                    case 'CREATE_WORKSPACE_PERMISSION': return 'tabler:shield-plus';
                    case 'DELETE_WORKSPACE_PERMISSION': return 'tabler:shield-minus';
                    case 'CREATE_WORKSPACE_REVIEW': return 'tabler:git-commit';
                    case 'UPDATE_WORKSPACE_REVIEW': return 'tabler:git-merge';
                    case 'DELETE_WORKSPACE_REVIEW': return 'tabler:git-branch-delete';
                    default: return 'tabler:history';
                }
            },

            getHistoryIconClass(operation) {
                const baseClasses = 'bg-surface-100 text-surface-600 dark:bg-surface-900/30 dark:text-surface-400';
                if (operation.includes('CREATE')) {
                    return 'bg-green-100 text-green-600 dark:bg-green-900/30 dark:text-green-400';
                } else if (operation.includes('UPDATE')) {
                    return 'bg-blue-100 text-blue-600 dark:bg-blue-900/30 dark:text-blue-400';
                } else if (operation.includes('DELETE')) {
                    return 'bg-red-100 text-red-600 dark:bg-red-900/30 dark:text-red-400';
                }
                return baseClasses;
            },

            getHistoryDescription(item) {
                const operationType = item.operation_type;
                let operationData = {};

                // Safely parse operation_data
                try {
                    if (item.operation_data) {
                        if (typeof item.operation_data === 'string') {
                            if (item.operation_data.startsWith('{') || item.operation_data.startsWith('[')) {
                                operationData = JSON.parse(item.operation_data);
                            }
                        } else if (typeof item.operation_data === 'object') {
                            operationData = item.operation_data;
                        }
                    }
                } catch (e) {
                    console.warn('Failed to parse operation_data:', e);
                    operationData = {};
                }

                switch(operationType) {
                    case 'CREATE_WORKSPACE':
                        const workspaceCreated = operationData.workspace_created;
                        return `Created workspace${workspaceCreated?.title ? ` "${workspaceCreated.title}"` : ''}${workspaceCreated?.workspace_id ? ` (ID: ${workspaceCreated.workspace_id.slice(-8)})` : ''}`;

                    case 'UPDATE_WORKSPACE':
                        const workspaceUpdated = operationData.workspace_updated;
                        if (workspaceUpdated?.fields_updated) {
                            const fields = Object.keys(workspaceUpdated.fields_updated);
                            const rowsAffected = workspaceUpdated.rows_affected ? ` (${workspaceUpdated.rows_affected} row affected)` : '';

                            if (fields.length === 1 && fields[0] === 'title') {
                                return `Updated workspace title to "${workspaceUpdated.fields_updated.title}"${rowsAffected}`;
                            } else if (fields.length === 1 && fields[0] === 'status') {
                                return `Changed workspace status to "${workspaceUpdated.fields_updated.status}"${rowsAffected}`;
                            } else if (fields.length === 1 && fields[0] === 'description') {
                                return `Updated workspace description${rowsAffected}`;
                            } else {
                                return `Updated workspace fields: ${fields.join(', ')}${rowsAffected}`;
                            }
                        }
                        return 'Updated workspace';

                    case 'DELETE_WORKSPACE':
                        return 'Deleted workspace';

                    case 'CREATE_WORKSPACE_ENTRY':
                        const entryCreated = operationData.entry_created;
                        return `Created entry${entryCreated?.entry_id ? ` "${entryCreated.entry_id}"` : ''}`;

                    case 'UPDATE_WORKSPACE_ENTRY':
                        const entryUpdated = operationData.entry_updated;
                        return `Updated entry${entryUpdated?.entry_id ? ` "${entryUpdated.entry_id}"` : ''}`;

                    case 'DELETE_WORKSPACE_ENTRY':
                        const entryDeleted = operationData.entry_deleted;
                        return `Deleted entry${entryDeleted?.entry_id ? ` "${entryDeleted.entry_id}"` : ''}`;

                    case 'CREATE_WORKSPACE_PERMISSION':
                        const permCreated = operationData.permission_created;
                        if (permCreated?.namespace_pattern && permCreated?.permission_type) {
                            const permId = permCreated.permission_id ? ` (ID: ${permCreated.permission_id.slice(-8)})` : '';
                            return `Added ${permCreated.permission_type} permission for "${permCreated.namespace_pattern}"${permId}`;
                        }
                        return 'Created permission';

                    case 'DELETE_WORKSPACE_PERMISSION':
                        const permDeleted = operationData.permission_deleted;
                        if (permDeleted?.namespace_pattern && permDeleted?.permission_type) {
                            const permId = permDeleted.permission_id ? ` (ID: ${permDeleted.permission_id.slice(-8)})` : '';
                            const rowsAffected = permDeleted.rows_affected ? ` - ${permDeleted.rows_affected} row affected` : '';
                            return `Removed ${permDeleted.permission_type} permission for "${permDeleted.namespace_pattern}"${permId}${rowsAffected}`;
                        }
                        return 'Deleted permission';

                    case 'CREATE_WORKSPACE_REVIEW':
                        const revCreated = operationData.review_created;
                        if (revCreated) {
                            const details = [];
                            if (revCreated.name) details.push(`"${revCreated.name}"`);
                            if (revCreated.content_type) details.push(`type: ${revCreated.content_type}`);
                            if (revCreated.status) details.push(`status: ${revCreated.status}`);
                            const revId = revCreated.review_id ? ` (ID: ${revCreated.review_id.slice(-8)})` : '';
                            return `Created review ${details.join(', ')}${revId}`;
                        }
                        return 'Created review';

                    case 'UPDATE_WORKSPACE_REVIEW':
                        const revUpdated = operationData.review_updated;
                        if (revUpdated) {
                            const revId = revUpdated.review_id ? ` (ID: ${revUpdated.review_id.slice(-8)})` : '';
                            const rowsAffected = revUpdated.rows_affected ? ` - ${revUpdated.rows_affected} row affected` : '';
                            return `Updated review${revId}${rowsAffected}`;
                        }
                        return 'Updated review';

                    case 'DELETE_WORKSPACE_REVIEW':
                        const revDeleted = operationData.review_deleted;
                        if (revDeleted) {
                            const revId = revDeleted.review_id ? ` (ID: ${revDeleted.review_id.slice(-8)})` : '';
                            const rowsAffected = revDeleted.rows_affected ? ` - ${revDeleted.rows_affected} row affected` : '';
                            return `Deleted review${revDeleted.name ? ` "${revDeleted.name}"` : ''}${revId}${rowsAffected}`;
                        }
                        return 'Deleted review';

                    default:
                        return operationType.replace(/_/g, ' ').toLowerCase().replace(/^\w/, c => c.toUpperCase());
                }
            },

            getHistoryDetails(item) {
                let operationData = {};
                try {
                    if (item.operation_data) {
                        if (typeof item.operation_data === 'string') {
                            if (item.operation_data.startsWith('{') || item.operation_data.startsWith('[')) {
                                operationData = JSON.parse(item.operation_data);
                            }
                        } else if (typeof item.operation_data === 'object') {
                            operationData = item.operation_data;
                        }
                    }
                } catch (e) {
                    return null;
                }

                const details = [];

                // Extract relevant details based on operation type
                switch(item.operation_type) {
                    case 'CREATE_WORKSPACE':
                        if (operationData.workspace_created?.workspace_id) {
                            details.push(`Workspace ID: ${operationData.workspace_created.workspace_id}`);
                        }
                        if (operationData.operation_result?.success) {
                            details.push(`Success: ${operationData.operation_result.success}`);
                        }
                        break;

                    case 'UPDATE_WORKSPACE':
                        if (operationData.workspace_updated?.workspace_id) {
                            details.push(`Workspace ID: ${operationData.workspace_updated.workspace_id}`);
                        }
                        if (operationData.workspace_updated?.fields_updated) {
                            details.push('Updated fields:');
                            Object.entries(operationData.workspace_updated.fields_updated).forEach(([key, value]) => {
                                details.push(`  ${key}: "${value}"`);
                            });
                        }
                        break;

                    case 'CREATE_WORKSPACE_PERMISSION':
                    case 'DELETE_WORKSPACE_PERMISSION':
                        const permData = operationData.permission_created || operationData.permission_deleted;
                        if (permData?.permission_id) {
                            details.push(`Permission ID: ${permData.permission_id}`);
                        }
                        break;

                    case 'CREATE_WORKSPACE_REVIEW':
                    case 'UPDATE_WORKSPACE_REVIEW':
                    case 'DELETE_WORKSPACE_REVIEW':
                        const revData = operationData.review_created || operationData.review_updated || operationData.review_deleted;
                        if (revData?.review_id) {
                            details.push(`Review ID: ${revData.review_id}`);
                        }
                        if (revData?.content_type) {
                            details.push(`Content Type: ${revData.content_type}`);
                        }
                        if (revData?.status) {
                            details.push(`Status: ${revData.status}`);
                        }
                        break;
                }

                // Add operation ID if available
                if (item.op_id) {
                    details.push(`Operation ID: ${item.op_id}`);
                }

                return details.length > 0 ? details : null;
            },

            // Context methods
            filterContexts() {
                if (!this.contextSearchTerm) {
                    this.filteredContexts = [...this.contexts];
                    return;
                }
                const term = this.contextSearchTerm.toLowerCase();
                this.filteredContexts = this.contexts.filter(context =>
                    (context.label || '').toLowerCase().includes(term) ||
                    (context.content || '').toLowerCase().includes(term)
                );
            },

            toggleContextDetails(contextId) {
                this.expandedContexts[contextId] = !this.expandedContexts[contextId];
                this.expandedContexts = { ...this.expandedContexts };
            },

            async createContext() {
                this.isSaving = true;
                try {
                    const response = await this.wippyApi.api.post(`/api/v1/workspaces/${this.workspaceId}/context`, this.contextForm);

                    if (!response.data.success) {
                        throw new Error(response.data.error || 'Failed to create context');
                    }

                    this.closeContextModal();
                    await this.loadWorkspace();

                    this.wippyApi.iframe.toast({
                        severity: 'success',
                        summary: 'Context Created',
                        detail: 'Context entry created successfully',
                        life: 3000
                    });
                } catch (err) {
                    console.error('Error creating context:', err);
                    this.wippyApi.iframe.toast({
                        severity: 'error',
                        summary: 'Create Failed',
                        detail: err.message,
                        life: 5000
                    });
                } finally {
                    this.isSaving = false;
                }
            },

            async updateContext() {
                this.isSaving = true;
                try {
                    const response = await this.wippyApi.api.put(`/api/v1/workspaces/${this.workspaceId}/context/${this.editingContextId}`, this.contextForm);

                    if (!response.data.success) {
                        throw new Error(response.data.error || 'Failed to update context');
                    }

                    this.closeContextModal();
                    await this.loadWorkspace();

                    this.wippyApi.iframe.toast({
                        severity: 'success',
                        summary: 'Context Updated',
                        detail: 'Context entry updated successfully',
                        life: 3000
                    });
                } catch (err) {
                    console.error('Error updating context:', err);
                    this.wippyApi.iframe.toast({
                        severity: 'error',
                        summary: 'Update Failed',
                        detail: err.message,
                        life: 5000
                    });
                } finally {
                    this.isSaving = false;
                }
            },

            editContext(context) {
                this.editingContextId = context.context_id;
                this.contextForm = {
                    label: context.label || '',
                    content: context.content || '',
                    content_type: context.content_type || 'text/plain'
                };
                this.showEditContextModal = true;
            },

            async deleteContext(contextId) {
                try {
                    const confirmed = await this.wippyApi.iframe.confirm({
                        message: 'Are you sure you want to delete this context entry? This action cannot be undone.',
                        header: 'Delete Context',
                        icon: 'tabler:trash',
                        acceptLabel: 'Delete',
                        rejectLabel: 'Cancel',
                        acceptClass: 'p-button-danger'
                    });

                    if (!confirmed) return;

                    const response = await this.wippyApi.api.delete(`/api/v1/workspaces/${this.workspaceId}/context/${contextId}`);

                    if (!response.data.success) {
                        throw new Error(response.data.error || 'Failed to delete context');
                    }

                    await this.loadWorkspace();

                    this.wippyApi.iframe.toast({
                        severity: 'success',
                        summary: 'Context Deleted',
                        detail: 'Context entry deleted successfully',
                        life: 3000
                    });
                } catch (err) {
                    console.error('Error deleting context:', err);
                    this.wippyApi.iframe.toast({
                        severity: 'error',
                        summary: 'Delete Failed',
                        detail: err.message,
                        life: 5000
                    });
                }
            },

            closeContextModal() {
                this.showCreateContextModal = false;
                this.showEditContextModal = false;
                this.editingContextId = null;
                this.contextForm = {
                    label: '',
                    content: '',
                    content_type: 'text/plain'
                };
            },

            getContentTypeIcon(contentType) {
                switch(contentType) {
                    case 'text/markdown': return 'tabler:markdown';
                    case 'application/json': return 'tabler:braces';
                    case 'text/plain': return 'tabler:file-text';
                    case 'application/yaml': return 'tabler:file-code';
                    default: return 'tabler:file';
                }
            },

            renderMarkdown(content) {
                if (!content) return '';
                try {
                    return marked.parse(content);
                } catch (err) {
                    console.error('Markdown parsing error:', err);
                    return `<pre>${content}</pre>`;
                }
            },

            // Context methods
            filterContexts() {
                if (!this.contextSearchTerm) {
                    this.filteredContexts = [...this.contexts];
                    return;
                }
                const term = this.contextSearchTerm.toLowerCase();
                this.filteredContexts = this.contexts.filter(context =>
                    (context.label || '').toLowerCase().includes(term) ||
                    (context.content || '').toLowerCase().includes(term)
                );
            },

            toggleContextDetails(contextId) {
                this.expandedContexts[contextId] = !this.expandedContexts[contextId];
                this.expandedContexts = { ...this.expandedContexts };
            },

            async createContext() {
                this.isSaving = true;
                try {
                    const response = await this.wippyApi.api.post(`/api/v1/workspaces/${this.workspaceId}/context`, this.contextForm);

                    if (!response.data.success) {
                        throw new Error(response.data.error || 'Failed to create context');
                    }

                    this.closeContextModal();
                    await this.loadWorkspace();

                    this.wippyApi.iframe.toast({
                        severity: 'success',
                        summary: 'Context Created',
                        detail: 'Context entry created successfully',
                        life: 3000
                    });
                } catch (err) {
                    console.error('Error creating context:', err);
                    this.wippyApi.iframe.toast({
                        severity: 'error',
                        summary: 'Create Failed',
                        detail: err.message,
                        life: 5000
                    });
                } finally {
                    this.isSaving = false;
                }
            },

            async updateContext() {
                this.isSaving = true;
                try {
                    const response = await this.wippyApi.api.put(`/api/v1/workspaces/${this.workspaceId}/context/${this.editingContextId}`, this.contextForm);

                    if (!response.data.success) {
                        throw new Error(response.data.error || 'Failed to update context');
                    }

                    this.closeContextModal();
                    await this.loadWorkspace();

                    this.wippyApi.iframe.toast({
                        severity: 'success',
                        summary: 'Context Updated',
                        detail: 'Context entry updated successfully',
                        life: 3000
                    });
                } catch (err) {
                    console.error('Error updating context:', err);
                    this.wippyApi.iframe.toast({
                        severity: 'error',
                        summary: 'Update Failed',
                        detail: err.message,
                        life: 5000
                    });
                } finally {
                    this.isSaving = false;
                }
            },

            editContext(context) {
                this.editingContextId = context.context_id;
                this.contextForm = {
                    label: context.label || '',
                    content: context.content || '',
                    content_type: context.content_type || 'text/plain'
                };
                this.showEditContextModal = true;
            },

            async deleteContext(contextId) {
                try {
                    const confirmed = await this.wippyApi.iframe.confirm({
                        message: 'Are you sure you want to delete this context entry? This action cannot be undone.',
                        header: 'Delete Context',
                        icon: 'tabler:trash',
                        acceptLabel: 'Delete',
                        rejectLabel: 'Cancel',
                        acceptClass: 'p-button-danger'
                    });

                    if (!confirmed) return;

                    const response = await this.wippyApi.api.delete(`/api/v1/workspaces/${this.workspaceId}/context/${contextId}`);

                    if (!response.data.success) {
                        throw new Error(response.data.error || 'Failed to delete context');
                    }

                    await this.loadWorkspace();

                    this.wippyApi.iframe.toast({
                        severity: 'success',
                        summary: 'Context Deleted',
                        detail: 'Context entry deleted successfully',
                        life: 3000
                    });
                } catch (err) {
                    console.error('Error deleting context:', err);
                    this.wippyApi.iframe.toast({
                        severity: 'error',
                        summary: 'Delete Failed',
                        detail: err.message,
                        life: 5000
                    });
                }
            },

            closeContextModal() {
                this.showCreateContextModal = false;
                this.showEditContextModal = false;
                this.editingContextId = null;
                this.contextForm = {
                    label: '',
                    content: '',
                    content_type: 'text/plain'
                };
            },

            getContentTypeIcon(contentType) {
                switch(contentType) {
                    case 'text/markdown': return 'tabler:markdown';
                    case 'application/json': return 'tabler:braces';
                    case 'text/plain': return 'tabler:file-text';
                    case 'application/yaml': return 'tabler:file-code';
                    default: return 'tabler:file';
                }
            },

            renderMarkdown(content) {
                if (!content) return '';
                try {
                    return marked.parse(content);
                } catch (err) {
                    console.error('Markdown parsing error:', err);
                    return `<pre>${content}</pre>`;
                }
            },

            formatTime(dateString) {
                if (!dateString) return 'N/A';
                try {
                    return new Date(dateString).toLocaleTimeString();
                } catch (e) {
                    return dateString;
                }
            },

            formatDate(dateString) {
                if (!dateString) return 'N/A';
                try {
                    const date = new Date(dateString);
                    return date.toLocaleString(undefined, {
                        year: 'numeric',
                        month: 'short',
                        day: 'numeric',
                        hour: '2-digit',
                        minute: '2-digit'
                    });
                } catch {
                    return dateString || 'N/A';
                }
            },

            formatJson(data) {
                if (data === undefined || data === null) return 'null';
                try {
                    return JSON.stringify(data, null, 2);
                } catch (e) {
                    return String(data);
                }
            }
        }));
    });
</script>
{{ end }}