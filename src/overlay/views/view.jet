                    status: 'draft'
                };
            },



            toggleReviewDetails(reviewId) {
                this.expandedReviews[reviewId] = !this.expandedReviews[reviewId];
                this.expandedReviews = { ...this.expandedReviews };
            },

            toggleHistoryDetails(opId) {
                this.expandedHistory[opId] = !this.expandedHistory[opId];
                this.expandedHistory = { ...this.expandedHistory };
            },

            // Entry methods
            generateDiff(original, modified) {
                const originalLines = original ? original.split('\n') : [];
                const modifiedLines = modified ? modified.split('\n') : [];
                const diff = [];
                const modifiedLineMap = new Map();
                modifiedLines.forEach((line, i) => {
                    if (!modifiedLineMap.has(line)) modifiedLineMap.set(line, []);
                    modifiedLineMap.get(line).push(i);
                });

                let lastMatchOriginal = -1;
                let lastMatchModified = -1;

                originalLines.forEach((line, i) => {
                    const matchesInModified = modifiedLineMap.get(line) || [];
                    const nextMatchIndex = matchesInModified.find(m => m > lastMatchModified);

                    if (nextMatchIndex !== undefined) {
                        for (let j = lastMatchOriginal + 1; j < i; j++) {
                            diff.push({ type: 'deleted', content: originalLines[j] });
                        }
                        for (let j = lastMatchModified + 1; j < nextMatchIndex; j++) {
                            diff.push({ type: 'added', content: modifiedLines[j] });
                        }
                        diff.push({ type: 'common', content: line });
                        lastMatchOriginal = i;
                        lastMatchModified = nextMatchIndex;
                    }
                });

                for (let i = lastMatchOriginal + 1; i < originalLines.length; i++) {
                    diff.push({ type: 'deleted', content: originalLines[i] });
                }
                for (let i = lastMatchModified + 1; i < modifiedLines.length; i++) {
                    diff.push({ type: 'added', content: modifiedLines[i] });
                }

                return diff;
            },



            editEntry(entryId) {
                this.editingEntryId = entryId;
                const entryData = this.entryViews[entryId]?.merged || this.entryViews[entryId]?.workspace || {};
                this.entryEditorContent = this.formatJson(entryData);
                this.updateEntryEditorPreview();
                this.showEntryEditor = true;
            },

            updateEntryEditorPreview() {
                try {
                    this.entryEditorPreview = JSON.parse(this.entryEditorContent);
                } catch (err) {
                    this.entryEditorPreview = null;
                }
            },

            async saveEntry() {
                this.isSaving = true;
                try {
                    if (!this.entryEditorPreview) {
                        throw new Error('Invalid JSON content');
                    }

                    const response = await this.wippyApi.api.put(`/api/v1/workspaces/${this.workspaceId}/entries/${this.editingEntryId}`, this.entryEditorPreview);

                    if (!response.data.success) {
                        throw new Error(response.data.error || 'Failed to save entry');
                    }

                    this.closeEntryEditor();
                    await this.loadWorkspace();

                    this.wippyApi.iframe.toast({
                        severity: 'success',
                        summary: 'Entry Saved',
                        detail: `Entry ${this.editingEntryId} saved successfully`,
                        life: 3000
                    });
                } catch (err) {
                    console.error('Error saving entry:', err);
                    this.wippyApi.iframe.toast({
                        severity: 'error',
                        summary: 'Save Failed',
                        detail: err.message,
                        life: 5000
                    });
                } finally {
                    this.isSaving = false;
                }
            },

            async resetEntry(entryId) {
                try {
                    const confirmed = await this.wippyApi.iframe.confirm({
                        message: `Are you sure you want to reset entry "${entryId}" to the main registry version? This will remove any workspace-specific changes.`,
                        header: 'Reset Entry',
                        icon: 'tabler:restore',
                        acceptLabel: 'Yes, Reset',
                        rejectLabel: 'Cancel',
                        acceptClass: 'p-button-warning',
                        rejectClass: 'p-button-secondary',
                    });

                    if (!confirmed) return;

                    const response = await this.wippyApi.api.post(`/api/v1/workspaces/${this.workspaceId}/entries/${entryId}/reset`);

                    if (!response.data.success) {
                        throw new Error(response.data.error || 'Failed to reset entry');
                    }

                    await this.loadWorkspace();

                    this.wippyApi.iframe.toast({
                        severity: 'success',
                        summary: 'Entry Reset',
                        detail: `Entry ${entryId} reset to main registry version`,
                        life: 3000
                    });
                } catch (err) {
                    console.error('Error resetting entry:', err);
                    this.wippyApi.iframe.toast({
                        severity: 'error',
                        summary: 'Reset Failed',
                        detail: err.message,
                        life: 5000
                    });
                }
            },

            async deleteEntry(entryId) {
                try {
                    const confirmed = await this.wippyApi.iframe.confirm({
                        message: `Are you sure you want to delete entry "${entryId}" from this workspace? This will mark the entry for deletion in the workspace overlay.`,
                        header: 'Delete Entry',
                        icon: 'tabler:trash',
                        acceptLabel: 'Yes, Delete',
                        rejectLabel: 'Cancel',
                        acceptClass: 'p-button-danger',
                        rejectClass: 'p-button-secondary',
                    });

                    if (!confirmed) return;

                    const response = await this.wippyApi.api.delete(`/api/v1/workspaces/${this.workspaceId}/entries/${entryId}`);

                    if (!response.data.success) {
                        throw new Error(response.data.error || 'Failed to delete entry');
                    }

                    await this.loadWorkspace();

                    this.wippyApi.iframe.toast({
                        severity: 'success',
