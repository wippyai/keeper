{{ extends "/common/layout" }}

{* Page title and description *}
{{ block title() }}Agents{{ end }}
{{ block metaDescription() }}Manage and configure agents{{ end }}

{{ block mainContent() }}
<div x-data="agentsApp" x-init="initialize()" x-cloak
     class="bg-surface-50 dark:bg-surface-700 shadow rounded-lg overflow-hidden mb-6">
    {{ yield headerSection() }}
    {{ yield contentSection() }}
    {{ yield statusMessage() }}
</div>
{{ end }}

{* Header Section *}
{{ block headerSection() }}
<div class="px-4 py-5 border-b border-surface-200 dark:border-surface-600 sm:px-6 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
    <div>
        <h3 class="text-lg leading-6 font-medium text-surface-900 dark:text-surface-100">Agents</h3>
        <p class="mt-1 text-sm text-surface-500 dark:text-surface-400">Manage and configure your agents</p>
    </div>
    <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto">
        {{ yield searchInput() }}
        {{ yield actionButtons() }}
    </div>
</div>
{{ end }}

{* Search Input *}
{{ block searchInput() }}
<div class="relative w-full sm:w-64">
    <input id="searchInput" type="text"
           x-model="searchTerm"
           @input="applyFilter()"
           class="block w-full pl-10 pr-10 py-2 border border-surface-300 dark:border-surface-600 rounded-md shadow-sm bg-white dark:bg-surface-700 text-surface-900 dark:text-surface-100 focus:outline-none focus:ring-primary-400 focus:border-primary-400 sm:text-sm"
           placeholder="Search by name, ID, class, etc.">
    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
        <iconify-icon icon="tabler:search"
                      class="h-5 w-5 text-surface-400 dark:text-surface-500"></iconify-icon>
    </div>
    <button id="clearSearchBtn" @click="clearSearch()" x-show="searchTerm.length > 0"
            class="absolute inset-y-0 right-0 pr-3 flex items-center cursor-pointer text-surface-400 hover:text-surface-600 dark:hover:text-surface-300">
        <iconify-icon icon="tabler:x" class="h-4 w-4"></iconify-icon>
    </button>
</div>
{{ end }}

{* Action Buttons *}
{{ block actionButtons() }}
<div class="flex space-x-2">
    <button id="refreshButton" @click="loadAgents" :disabled="isLoading"
            class="inline-flex items-center px-3 py-1.5 border border-surface-300 dark:border-surface-600 rounded-md text-surface-700 dark:text-surface-300 bg-white dark:bg-surface-800 hover:bg-surface-100 dark:hover:bg-surface-700 disabled:opacity-50">
        <template x-if="isLoading">
            <iconify-icon icon="tabler:loader" class="mr-1.5 animate-spin" width="16" height="16"></iconify-icon>
        </template>
        <template x-if="!isLoading">
            <iconify-icon icon="tabler:refresh" class="mr-1.5" width="16" height="16"></iconify-icon>
        </template>
        <span x-text="isLoading ? 'Loading...' : 'Refresh'"></span>
    </button>
</div>
{{ end }}

{* Main Content Section *}
{{ block contentSection() }}
{{ yield loadingIndicator() }}
{{ yield agentList() }}
{{ yield emptyState() }}
{{ end }}

{* Loading Indicator *}
{{ block loadingIndicator() }}
<div id="loadingIndicator" x-show="isLoading" class="flex justify-center px-4 sm:px-6 py-8">
    <div class="animate-spin rounded-full h-8 w-8 border-t-2 border-b-2 border-primary-600"></div>
</div>
{{ end }}

{* Agent List Table *}
{{ block agentList() }}
<div id="agentsContainer" x-show="!isLoading && filteredAgents.length > 0">
    <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-surface-200 dark:divide-surface-600 table-auto">
            {{ yield tableHeader() }}
            {{ yield tableBody() }}
        </table>
    </div>
    {{ yield pagination() }}
</div>
{{ end }}

{* Table Header *}
{{ block tableHeader() }}
<thead class="bg-surface-100 dark:bg-surface-800">
<tr>
    <th scope="col"
        class="px-6 py-3 text-left text-xs font-medium text-surface-500 dark:text-surface-400 uppercase tracking-wider w-1/3">
        Agent Information
    </th>
    <th scope="col"
        class="px-6 py-3 text-left text-xs font-medium text-surface-500 dark:text-surface-400 uppercase tracking-wider w-1/6">
        Model & Config
    </th>
    <th scope="col"
        class="px-6 py-3 text-left text-xs font-medium text-surface-500 dark:text-surface-400 uppercase tracking-wider w-1/6">
        Components
    </th>
    <th scope="col"
        class="px-6 py-3 text-left text-xs font-medium text-surface-500 dark:text-surface-400 uppercase tracking-wider w-1/4">
        Classes
    </th>
    <th scope="col"
        class="px-6 py-3 text-right text-xs font-medium text-surface-500 dark:text-surface-400 uppercase tracking-wider w-auto">
        Actions
    </th>
</tr>
</thead>
{{ end }}

{* Table Body *}
{{ block tableBody() }}
<tbody id="agentsList"
       class="bg-white dark:bg-surface-700 divide-y divide-surface-200 dark:divide-surface-600">
<template x-for="agent in paginatedAgents" :key="agent.id">
    <tr class="hover:bg-surface-50 dark:hover:bg-surface-600">
        {{ yield agentInfoCell() }}
        {{ yield modelConfigCell() }}
        {{ yield componentsCell() }}
        {{ yield classesCell() }}
        {{ yield actionsCell() }}
    </tr>
</template>
</tbody>
{{ end }}

{* Agent Information Cell *}
{{ block agentInfoCell() }}
<td class="px-6 py-4 whitespace-normal break-words">
    <div>
        <div class="flex items-center justify-between">
            <span class="text-sm font-medium text-surface-900 dark:text-surface-100" x-text="agent.title || agent.name || ''"></span>
        </div>

        <div class="text-xs font-mono mt-0.5 flex items-center">
            <span class="text-surface-500 dark:text-surface-400" x-text="agent.id || ''"></span>
        </div>

        <div class="text-xs text-surface-500 dark:text-surface-400 mt-1"
             x-html="truncateDescription(agent.description)">
        </div>

        <!-- Badges for special features -->
        <div class="mt-1.5 flex flex-wrap gap-1.5" x-show="agent.has_memory_contract">
            {{ yield memoryContractBadge() }}
        </div>
    </div>
</td>
{{ end }}

{* Memory Contract Badge *}
{{ block memoryContractBadge() }}
<template x-if="agent.has_memory_contract">
    <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-blue-100 dark:bg-blue-900 text-blue-800 dark:text-blue-200">
        <iconify-icon icon="tabler:database" class="mr-1" width="12" height="12"></iconify-icon>
        Memory
    </span>
</template>
{{ end }}

{* Model & Config Cell *}
{{ block modelConfigCell() }}
<td class="px-6 py-4 whitespace-nowrap">
    <div class="space-y-1">
        <div class="text-xs text-surface-900 dark:text-surface-100 font-medium" x-show="agent.model">
            <span x-text="agent.model"></span>
        </div>
        <div class="text-xs text-surface-500 dark:text-surface-400" x-show="!agent.model">
            No model set
        </div>

        <div class="flex flex-wrap gap-1" x-show="agent.max_tokens || agent.temperature !== undefined || agent.thinking_effort">
            <span x-show="agent.max_tokens" class="inline-flex items-center px-1.5 py-0.5 rounded text-xs bg-surface-100 dark:bg-surface-600 text-surface-700 dark:text-surface-300">
                <iconify-icon icon="tabler:database" class="mr-1" width="12" height="12"></iconify-icon>
                <span x-text="formatNumber(agent.max_tokens)"></span>
            </span>
            <span x-show="agent.temperature !== undefined" class="inline-flex items-center px-1.5 py-0.5 rounded text-xs bg-surface-100 dark:bg-surface-600 text-surface-700 dark:text-surface-300">
                <iconify-icon icon="tabler:temperature" class="mr-1" width="12" height="12"></iconify-icon>
                <span x-text="(agent.temperature || 0).toFixed(1)"></span>
            </span>
            <span x-show="agent.thinking_effort" class="inline-flex items-center px-1.5 py-0.5 rounded text-xs bg-surface-100 dark:bg-surface-600 text-surface-700 dark:text-surface-300">
                <iconify-icon icon="tabler:brain" class="mr-1" width="12" height="12"></iconify-icon>
                <span x-text="agent.thinking_effort"></span>
            </span>
        </div>
    </div>
</td>
{{ end }}

{* Components Cell *}
{{ block componentsCell() }}
<td class="px-6 py-4 whitespace-nowrap">
    <div class="flex flex-wrap gap-1">
        <span x-show="agent.tools_count > 0" class="inline-flex items-center px-1.5 py-0.5 rounded text-xs bg-green-100 dark:bg-green-800 text-green-800 dark:text-green-200">
            <iconify-icon icon="tabler:tool" class="mr-1" width="12" height="12"></iconify-icon>
            <span x-text="agent.tools_count + ' tools'"></span>
        </span>
        <span x-show="agent.traits_count > 0" class="inline-flex items-center px-1.5 py-0.5 rounded text-xs bg-purple-100 dark:bg-purple-800 text-purple-800 dark:text-purple-200">
            <iconify-icon icon="tabler:dna" class="mr-1" width="12" height="12"></iconify-icon>
            <span x-text="agent.traits_count + ' traits'"></span>
        </span>
        <span x-show="agent.delegates_count > 0" class="inline-flex items-center px-1.5 py-0.5 rounded text-xs bg-blue-100 dark:bg-blue-800 text-blue-800 dark:text-blue-200">
            <iconify-icon icon="tabler:directions" class="mr-1" width="12" height="12"></iconify-icon>
            <span x-text="agent.delegates_count + ' delegates'"></span>
        </span>
        <span x-show="agent.memory_count > 0" class="inline-flex items-center px-1.5 py-0.5 rounded text-xs bg-yellow-100 dark:bg-yellow-800 text-yellow-800 dark:text-yellow-200">
            <iconify-icon icon="tabler:history" class="mr-1" width="12" height="12"></iconify-icon>
            <span x-text="agent.memory_count + ' memory'"></span>
        </span>
        <span x-show="agent.start_prompts_count > 0" class="inline-flex items-center px-1.5 py-0.5 rounded text-xs bg-orange-100 dark:bg-orange-800 text-orange-800 dark:text-orange-200">
            <iconify-icon icon="tabler:prompt" class="mr-1" width="12" height="12"></iconify-icon>
            <span x-text="agent.start_prompts_count + ' prompts'"></span>
        </span>

        <!-- Show message when no components -->
        <span x-show="agent.tools_count === 0 && agent.traits_count === 0 && agent.delegates_count === 0 && agent.memory_count === 0 && agent.start_prompts_count === 0"
              class="text-xs text-surface-400 dark:text-surface-500 italic">No components</span>
    </div>
</td>
{{ end }}

{* Classes Cell *}
{{ block classesCell() }}
<td class="px-6 py-4 whitespace-normal">
    <div class="flex flex-wrap items-start gap-1">
        <template x-if="agent.class && agent.class.length > 0">
            <template x-for="cls in agent.class" :key="cls">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-100 dark:bg-indigo-900 text-indigo-800 dark:text-indigo-200 mr-1 mb-1" x-text="cls"></span>
            </template>
        </template>
        <template x-if="!agent.class || agent.class.length === 0">
            <span class="text-surface-400 dark:text-surface-500 text-xs italic">No classes</span>
        </template>
    </div>
</td>
{{ end }}

{* Actions Cell *}
{{ block actionsCell() }}
<td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium space-x-2">
    <button @click="editAgent(agent.id)"
            class="inline-flex items-center px-3 py-1.5 border border-transparent text-xs font-medium rounded shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
        <iconify-icon icon="tabler:pencil" width="16" height="16"></iconify-icon>
    </button>
    <button @click="startChat(agent.id)"
            class="inline-flex items-center px-3 py-1.5 border border-transparent text-xs font-medium rounded shadow-sm text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500">
        <iconify-icon icon="tabler:message-circle" width="16" height="16"></iconify-icon>
    </button>
</td>
{{ end }}

{* Pagination *}
{{ block pagination() }}
<div class="flex items-center justify-between border-t border-surface-200 dark:border-surface-600 px-4 sm:px-6 py-5">
    <div class="text-sm text-surface-500 dark:text-surface-400">
        Showing <span id="startCount" x-text="startCount"></span> to <span id="endCount" x-text="endCount"></span> of <span id="totalCount" x-text="totalAgents"></span> agents
    </div>
    <div class="flex">
        <button id="prevPageBtn" @click="changePage(currentPage - 1)" :disabled="currentPage === 0"
                class="relative inline-flex items-center px-4 py-2 border border-surface-300 dark:border-surface-600 text-sm font-medium rounded-md text-surface-700 dark:text-surface-300 bg-white dark:bg-surface-800 hover:bg-surface-100 dark:hover:bg-surface-700 mr-3 disabled:opacity-50 disabled:cursor-not-allowed">
            Previous
        </button>
        <button id="nextPageBtn" @click="changePage(currentPage + 1)" :disabled="currentPage >= totalPages - 1"
                class="relative inline-flex items-center px-4 py-2 border border-surface-300 dark:border-surface-600 text-sm font-medium rounded-md text-surface-700 dark:text-surface-300 bg-white dark:bg-surface-800 hover:bg-surface-100 dark:hover:bg-surface-700 disabled:opacity-50 disabled:cursor-not-allowed">
            Next
        </button>
    </div>
</div>
{{ end }}

{* Empty State *}
{{ block emptyState() }}
<div id="emptyState" x-show="!isLoading && filteredAgents.length === 0" class="text-center px-4 sm:px-6 py-12">
    <div class="mx-auto h-12 w-12 text-surface-400 dark:text-surface-600">
        <iconify-icon :icon="searchTerm ? 'tabler:search-off' : 'tabler:robot-off'" width="48" height="48"></iconify-icon>
    </div>
    <h3 class="mt-2 text-sm font-medium text-surface-900 dark:text-surface-100"
        x-text="searchTerm ? 'No matching agents found' : 'No agents found'"></h3>
    <p class="mt-1 text-sm text-surface-500 dark:text-surface-400"
       x-text="searchTerm ? 'Try adjusting your search terms.' : 'No agents available.'"></p>
</div>
{{ end }}

{* Status Message *}
{{ block statusMessage() }}
<div x-data
     x-show="$store.agentsStatus.show"
     @status-update.window="$store.agentsStatus.update($event.detail)"
     x-transition:enter="transform ease-out duration-300 transition"
     x-transition:enter-start="translate-y-full opacity-0"
     x-transition:enter-end="translate-y-0 opacity-100"
     x-transition:leave="transition ease-in duration-300"
     x-transition:leave-start="translate-y-0 opacity-100"
     x-transition:leave-end="translate-y-full opacity-0"
     class="fixed bottom-0 right-0 p-6 z-50"
     style="max-width: 400px;">
    <div class="flex items-center p-4 rounded-lg shadow-lg"
         :class="{
            'bg-green-100 dark:bg-green-900 text-green-700 dark:text-green-200': $store.agentsStatus.type === 'success',
            'bg-red-100 dark:bg-red-900 text-red-700 dark:text-red-200': $store.agentsStatus.type === 'error',
            'bg-blue-100 dark:bg-blue-900 text-blue-700 dark:text-blue-200': $store.agentsStatus.type === 'info'
         }">
        <iconify-icon :icon="$store.agentsStatus.icon" class="h-5 w-5 mr-3"></iconify-icon>
        <p class="text-sm font-medium" x-text="$store.agentsStatus.message"></p>
        <button @click="$store.agentsStatus.hide()" class="ml-auto -mx-1.5 -my-1.5 p-1.5 inline-flex h-8 w-8 rounded-md focus:outline-none focus:ring-2 focus:ring-offset-2"
                :class="{
                     'text-green-500 hover:bg-green-200 dark:hover:bg-green-800 focus:ring-green-600 dark:focus:ring-offset-green-900': $store.agentsStatus.type === 'success',
                     'text-red-500 hover:bg-red-200 dark:hover:bg-red-800 focus:ring-red-600 dark:focus:ring-offset-red-900': $store.agentsStatus.type === 'error',
                     'text-blue-500 hover:bg-blue-200 dark:hover:bg-blue-800 focus:ring-blue-600 dark:focus:ring-offset-blue-900': $store.agentsStatus.type === 'info'
                 }">
            <span class="sr-only">Dismiss</span>
            <iconify-icon icon="tabler:x" class="h-5 w-5"></iconify-icon>
        </button>
    </div>
</div>
{{ end }}

{{ block customJs() }}
<script>
    // Define escapeHtml globally
    function escapeHtml(unsafe) {
        if (unsafe === null || unsafe === undefined) return '';
        return unsafe
            .toString()
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/"/g, "&quot;")
            .replace(/'/g, "&#039;");
    }

    document.addEventListener('alpine:init', () => {
        // Status store for notifications
        Alpine.store('agentsStatus', {
            show: false, type: 'info', message: '', icon: 'tabler:info-circle', timeout: null,
            update(detail) {
                if (this.timeout) clearTimeout(this.timeout);
                this.type = detail.type || 'info'; this.message = detail.message || '';
                this.icon = 'tabler:info-circle';
                if (this.type === 'success') this.icon = 'tabler:check-circle';
                if (this.type === 'error') this.icon = 'tabler:alert-circle';
                this.show = true;
                this.timeout = setTimeout(() => this.hide(), detail.duration || 5000);
            },
            hide() { if (this.timeout) clearTimeout(this.timeout); this.show = false; this.timeout = null; }
        });

        // Main agents component
        Alpine.data('agentsApp', () => ({
            // State variables
            agents: [],
            filteredAgents: [],
            isLoading: true,
            searchTerm: '',
            currentPage: 0,
            pageSize: 50,
            wippyApi: null,
            navigateApi: null,

            // Initialization
            async initialize() {
                console.log('Initializing Agents Alpine component...');
                this.isLoading = true;
                try {
                    if (typeof window.initWippyApi !== 'function') {
                        throw new Error("initWippyApi function not found.");
                    }

                    // Initialize the Wippy API
                    this.wippyApi = await window.initWippyApi();

                    if (this.wippyApi?.iframe) {
                        this.navigateApi = this.wippyApi.iframe;
                        console.log('Wippy API Config initialized');
                    } else {
                        throw new Error("Navigation API not available.");
                    }

                    await this.loadAgents();
                } catch (err) {
                    console.error('Failed to initialize:', err);
                    this.showStatus('error', `Initialization failed: ${err.message}`);
                    this.isLoading = false;

                    if (this.wippyApi?.iframe?.handleError) {
                        this.wippyApi.iframe.handleError(err);
                    }
                }
            },

            // Data loading
            async loadAgents() {
                this.isLoading = true;
                console.log('Loading agents...');

                try {
                    const response = await this.wippyApi.api.get('/api/v1/keeper/agents/list');

                    if (!response.data.success) {
                        throw new Error(response.data.error || 'API error');
                    }

                    this.agents = response.data.agents || [];
                    this.filteredAgents = [...this.agents];
                    console.log(`Loaded ${this.agents.length} agents.`);
                } catch (error) {
                    console.error('Error loading agents:', error);
                    this.agents = [];
                    this.filteredAgents = [];
                    this.showStatus('error', `Failed to load agents: ${error.message}`);
                } finally {
                    this.isLoading = false;
                }
            },

            // Search and filtering
            applyFilter() {
                // Reset pagination
                this.currentPage = 0;

                // Get clean search term
                const term = (this.searchTerm || '').toLowerCase().trim();

                // If empty, show all agents
                if (!term) {
                    this.filteredAgents = [...this.agents];
                    return;
                }

                // Simple string match helper
                const matches = (text, searchTerm) => {
                    if (!text) return false;
                    return String(text).toLowerCase().includes(searchTerm);
                };

                // Filter agents
                this.filteredAgents = this.agents.filter(agent => {
                    if (!agent) return false;

                    // Basic field checks
                    if (matches(agent.title, term)) return true;
                    if (matches(agent.name, term)) return true;
                    if (matches(agent.id, term)) return true;
                    if (matches(agent.description, term)) return true;
                    if (matches(agent.model, term)) return true;

                    // Check classes
                    if (Array.isArray(agent.class)) {
                        for (let i = 0; i < agent.class.length; i++) {
                            if (matches(agent.class[i], term)) return true;
                        }
                    }

                    // Check tags
                    if (Array.isArray(agent.tags)) {
                        for (let i = 0; i < agent.tags.length; i++) {
                            if (matches(agent.tags[i], term)) return true;
                        }
                    }

                    return false;
                });
            },

            // Clear search
            clearSearch() {
                this.searchTerm = '';
                this.filteredAgents = [...this.agents];
                this.currentPage = 0;
            },

            // Pagination
            get paginatedAgents() {
                const s = this.currentPage * this.pageSize;
                return (Array.isArray(this.filteredAgents) ? this.filteredAgents.slice(s, s + this.pageSize) : []);
            },

            get totalPages() {
                const t = Array.isArray(this.filteredAgents) ? this.filteredAgents.length : 0;
                return Math.ceil(t / this.pageSize);
            },

            get totalAgents() {
                return Array.isArray(this.filteredAgents) ? this.filteredAgents.length : 0;
            },

            get startCount() {
                return this.totalAgents === 0 ? 0 : this.currentPage * this.pageSize + 1;
            },

            get endCount() {
                const e = (this.currentPage + 1) * this.pageSize;
                return Math.min(e, this.totalAgents);
            },

            changePage(newPage) {
                if (newPage >= 0 && newPage < this.totalPages) {
                    this.currentPage = newPage;
                }
            },

            // Navigation actions
            editAgent(agentId) {
                console.log(`Navigating to edit agent: ${agentId}`);
                if (this.navigateApi && typeof this.navigateApi.navigate === 'function') {
                    const targetPath = `/keeper/${agentId}`;
                    console.log(`Calling navigateApi with path: ${targetPath}`);
                    this.navigateApi.navigate(targetPath);
                } else {
                    console.warn("Navigate API not available.");
                    this.showStatus('error', "Navigation not available.");
                }
            },

            async startChat(agentId) {
                try {
                    console.log('Starting chat with agent:', agentId);
                    this.showStatus('info', 'Starting chat...');

                    // Get the start token for the agent
                    const response = await this.wippyApi.api.get('/api/v1/keeper/agents/start-agent', {
                        params: { agent: agentId }
                    });

                    if (!response.data.success || !response.data.start_token) {
                        throw new Error(response.data.error || 'Failed to get agent start token');
                    }

                    // Check if iframe API and startChat method are available
                    if (!this.navigateApi) {
                        console.error('Navigate API not available');
                        throw new Error('Navigation API not available');
                    }

                    if (typeof this.navigateApi.startChat !== 'function') {
                        console.error('startChat method not available on navigate API', this.navigateApi);
                        throw new Error('Chat API not available on navigation interface');
                    }

                    // Start the chat with the token
                    console.log('Attempting to start chat with token...');
                    const chatResult = await this.navigateApi.startChat(response.data.start_token, true);

                    this.showStatus('success', 'Chat started successfully');
                } catch (error) {
                    console.error('Error starting chat:', error);
                    this.showStatus('error', `Failed to start chat: ${error.message}`);
                }
            },

            // UI helpers
            truncateDescription(description) {
                const desc = description || '';
                if (desc.length > 80) {
                    return escapeHtml(desc.substring(0, 80)) + '...';
                }
                const escapedDesc = escapeHtml(desc);
                return escapedDesc ? escapedDesc : '<span class="italic text-surface-500 dark:text-surface-400">No description</span>';
            },

            formatNumber(num) {
                return new Intl.NumberFormat().format(num);
            },

            showStatus(type, message, duration = 5000) {
                window.dispatchEvent(new CustomEvent('status-update', { detail: { type, message, duration } }));
            }
        }));

        console.log('[DEBUG] Agents component initialized');
    });
</script>
{{ end }}