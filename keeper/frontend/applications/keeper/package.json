{
  "name": "@wippy/app-keeper",
  "version": "1.0.0",
  "license": "BSL-1.1",
  "specification": "wippy-component-1.0",
  "title": "Keeper",
  "description": "Wippy control plane for registry governance, agents, tasks, MCP, Hub, and runtime operations",
  "files": [
    "dist/",
    "package.json"
  ],
  "browser": "dist/app.js",
  "wippy": {
    "type": "page",
    "title": "Keeper",
    "icon": "tabler:shield-code",
    "path": "dist/app.html",
    "proxy": {
      "enabled": true,
      "injections": {
        "css": {
          "fonts": true,
          "themeConfig": true,
          "iframe": true,
          "primevue": true,
          "markdown": true,
          "customCss": true,
          "customVariables": true
        },
        "tailwindConfig": false,
        "resizeObserver": false,
        "preventLinkClicks": false,
        "iconifyIcons": false
      }
    },
    "scripts": {
      "build": "build",
      "debug": "build:debug"
    }
  },
  "scripts": {
    "build": "vite build",
    "build:debug": "KEEPER_SOURCEMAP=true vite build --mode development",
    "dev": "vite build --watch",
    "type-check": "vue-tsc --build --force",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@wippy-fe/theme": "^0.0.12",
    "chart.js": "^4.5.1",
    "d3-force": "^3.0.0",
    "monaco-editor": "^0.55.1"
  },
  "devDependencies": {
    "@testing-library/vue": "^8.1.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.6",
    "@wippy-fe/types-global-proxy": "^0.0.12",
    "autoprefixer": "^10.4.0",
    "happy-dom": "^20.8.4",
    "jsdom": "^29.0.0",
    "postcss": "^8.4.0",
    "primevue": "^4.3.3",
    "tailwindcss": "3",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.0",
    "vue": "^3.5.0",
    "vue-router": "^4.6.4",
    "vue-tsc": "^2.0.0"
  },
  "peerDependencies": {
    "@iconify/vue": "^5.0.0",
    "@wippy-fe/proxy": "^0.0.12",
    "axios": "^1.0.0",
    "luxon": "^3.5.0",
    "pinia": "^2.1.0",
    "primevue": "^4.3.3",
    "vue": "^3.5.0",
    "vue-router": "^4.0.0"
  }
}
